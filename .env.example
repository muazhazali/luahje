# Luahje Environment Configuration
# Copy this file to .env and update the values as needed

# =============================================================================
# Database (Required)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Local development (Docker):
DATABASE_URL="postgresql://luahje:luahje_dev@localhost:5432/luahje?schema=public"
#
# Production (Neon, Supabase, etc.):
# DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# =============================================================================
# CORS Configuration (Optional)
# =============================================================================
# Comma-separated list of allowed origins for API requests
# Used in production to restrict API access
# ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# =============================================================================
# Site Configuration (Optional)
# =============================================================================
# Public URL for SEO/meta tags
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
