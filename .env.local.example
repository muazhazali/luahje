# Local Development Environment Variables
# Copy this file to .env.local for local development overrides
# These values take precedence over .env

# Database (local development uses Docker PostgreSQL)
DATABASE_URL="postgresql://luahje:luahje_dev@localhost:5432/luahje?schema=public"

# Optional: Allow additional origins in development
ALLOWED_ORIGINS="http://localhost:3000,http://192.168.1.112:3000,http://127.0.0.1:3000"

# Optional: Local site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
